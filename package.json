{
  "name": "bisqueuploader",
  "version": "0.1.0",
  "description": "A desktop uploader for BisQue iRODS storage using GoCommands.",
  "main": "src/main.js",
  "author": "",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "webapp": "node webapp/dev-server.js",
    "check": "node --check src/main.js && node --check src/bisque-client.js && node --check src/preload.js && node --check src/renderer.js && node --check webapp/app.js && node --check webapp/sw.js && node --check webapp/dev-server.js && node --check test/bisque-client.test.js",
    "test": "node --test",
    "dist": "electron-builder",
    "dist:linux": "electron-builder --linux AppImage --x64 --publish never",
    "dist:mac": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac zip --universal --publish never",
    "dist:mac:dmg": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg --universal --publish never",
    "dist:win": "electron-builder --win nsis --x64 --publish never"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "edu.ucsb.bisque.irod-uploader",
    "productName": "BisqueUploader",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "artifactName": "BisqueUploader-${os}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "target": [
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  }
}
